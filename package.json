{
  "name": "@zendesk/retrace",
  "version": "0.0.0",
  "description": "define and capture Product Operation Traces along with computed metrics with an optional friendly React beacon API",
  "keywords": [
    "headless",
    "otel",
    "opentelemetry",
    "retrace",
    "trace",
    "tracing",
    "hook",
    "measure",
    "react",
    "time-to-interactive",
    "time-to-render",
    "timing",
    "tti",
    "zendesk"
  ],
  "bugs": {
    "url": "https://github.com/zendesk/retrace/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zendesk/retrace.git"
  },
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Zendesk",
  "collaborators": [
    "Bazyli Brzóska <bbrzoska@zendesk.com>",
    "Evan Jenkins <evan.jenkins@zendesk.com>",
    "Cynthia Ma <cma@zendesk.com>"
  ],
  "exports": {
    ".": {
      "import": "./esm/main.js",
      "require": "./cjs/main.js"
    },
    "./*": {
      "import": "./esm/*.js",
      "require": "./cjs/*.js"
    },
    "./cjs": {
      "require": "./cjs/main.js"
    },
    "./cjs/*": {
      "require": "./cjs/*.js"
    },
    "./esm/*": {
      "import": "./esm/*.js"
    },
    "./src/*": {
      "default": "./src/*"
    },
    "./package.json": "./package.json"
  },
  "main": "cjs/main.js",
  "module": "esm/main.js",
  "source": "src/main.ts",
  "scripts": {
    "dev": "echo \"export * from '../src/main'\" > ./esm/main.d.ts && yarn build:esm:webpack --watch",
    "build": "yarn build:cjs && yarn build:esm",
    "build:cjs": "rm -rf cjs && tsc -p tsconfig.build.cjs.json",
    "build:esm": "rm -rf esm && yarn build:esm:ts && yarn build:esm:webpack && cp package.esm.json esm/package.json",
    "build:esm:webpack": "TS_NODE_PROJECT=tsconfig.webpack.json yarn webpack build --entry ./src/main --mode development",
    "build:esm:ts": "tsc -p tsconfig.build.esm.json",
    "clean": "git clean -dfX --exclude=node_modules src",
    "format": "prettier --write \"./{src,tests,.config}/**/!(*.d).{.js,jsx,ts,tsx,json,md}\"",
    "postinstallDev": "yarn prepare",
    "prepare": "husky install .config/husky",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "test": "yarn test:format && yarn test:types && yarn test:lint && yarn test:code",
    "test:code": "vitest",
    "test:format": "yarn prettier --check \"./{src,tests,.config}/**/!(*.d).{.js,jsx,ts,tsx,json,md}\"",
    "test:lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "test:types": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "engines": {
    "node": ">=22"
  },
  "release": {
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "master",
      {
        "name": "main",
        "channel": false
      },
      {
        "name": "next",
        "prerelease": true
      },
      {
        "name": "beta",
        "prerelease": true
      },
      {
        "name": "alpha",
        "prerelease": true
      }
    ],
    "tagFormat": "${version}"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-docs": "^10.2.11",
    "@storybook/addon-links": "^10.2.11",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/react-webpack5": "^10.2.11",
    "@svgr/core": "^8.1.0",
    "@svgr/webpack": "^8.1.0",
    "@swc/core": "^1.15.13",
    "@swc/types": "^0.1.25",
    "@types/jest": "^30.0.0",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@types/webpack-sources": "^3.2.3",
    "@visx/annotation": "^3.12.0",
    "@visx/axis": "^3.12.0",
    "@visx/brush": "^3.12.0",
    "@visx/curve": "^3.12.0",
    "@visx/event": "^3.12.0",
    "@visx/gradient": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/legend": "^3.12.0",
    "@visx/mock-data": "^3.12.0",
    "@visx/pattern": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/stats": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "@visx/vendor": "^3.12.0",
    "@visx/visx": "^3.12.0",
    "@zendeskgarden/css-bedrock": "^10.0.1",
    "@zendeskgarden/react-accordions": "^9.14.2",
    "@zendeskgarden/react-avatars": "^9.14.2",
    "@zendeskgarden/react-buttons": "^9.14.2",
    "@zendeskgarden/react-chrome": "^9.14.2",
    "@zendeskgarden/react-dropdowns": "^9.14.2",
    "@zendeskgarden/react-grid": "^9.14.2",
    "@zendeskgarden/react-loaders": "^9.14.2",
    "@zendeskgarden/react-notifications": "^9.14.2",
    "@zendeskgarden/react-tables": "^9.14.2",
    "@zendeskgarden/react-theming": "^9.14.2",
    "@zendeskgarden/react-typography": "^9.14.2",
    "@zendeskgarden/svg-icons": "^8.1.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.3",
    "eslint-config-niieani": "^1.2.10",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lodash.debounce": "^4.0.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-test-renderer": "^19.2.4",
    "semantic-release": "^25.0.3",
    "storybook": "^10.2.11",
    "style-loader": "^4.0.0",
    "styled-components": "^6.3.11",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "url-loader": "^4.1.1",
    "vitest": "^4.0.18",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-sources": "^3.3.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "resolutions": {
    "webpack": "patch:webpack@npm:5.105.2#.yarn/patches/webpack-npm-5.74.0-f5b838a00d.patch",
    "@swc/types": "0.1.25",
    "@swc/core": "1.15.13",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "5.9.3",
    "tar": "7.5.9",
    "js-yaml": "4.1.1",
    "lodash": "4.17.23",
    "lodash-es": "4.17.23"
  },
  "packageManager": "yarn@4.12.0",
  "publishConfig": {
    "access": "public"
  },
  "browserslist": [
    "last 3 versions and > 1%",
    "not dead"
  ],
  "files": [
    "src",
    "cjs",
    "esm",
    "docs"
  ],
  "dependencies": {
    "rxjs": "^7.8.2"
  }
}
