    "@zendeskgarden/react-notifications": "^9.15.0",
    "@zendeskgarden/react-tables": "^9.15.0",
    "@zendeskgarden/react-theming": "^9.15.0",
    "@zendeskgarden/react-typography": "^9.15.0",
    "@zendeskgarden/svg-icons": "^8.4.0",
    "css-loader": "^7.1.4",
    "eslint": "10.2.1",
    "jest": "30.3",
    "lodash.debounce": "^4.0.8",
    "prettier-2": "npm:prettier@^3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-test-renderer": "^19.2.5",
    "semantic-release": "^25.0.3",
    "storybook": "^10.3.5",
    "style-loader": "^4.0.0",
    "styled-components": "^6.4.1",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "url-loader": "^4.1.1",
    "vitest": "^4.1.5",
    "webpack": "5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-sources": "^3.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
